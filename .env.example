# STADO×Qwen — env file. Copy to .env and fill in. NEVER commit .env.
#
# VITE_* vars are consumed at IMAGE BUILD TIME (baked into the JS bundle);
# everything else at CONTAINER RUNTIME.

# ── Qwen (Alibaba Cloud Model Studio) — REQUIRED, this is the demo ───────────
# One key drives everything: realtime voice, vision grounding, survey
# perimeter detection, and mission-report summaries.
# Get a key at https://modelstudio.console.alibabacloud.com/.
DASHSCOPE_API_KEY=

# International (Singapore) accounts use the workspace-scoped realtime endpoint:
#   wss://<WorkspaceId>.ap-southeast-1.maas.aliyuncs.com/api-ws/v1/realtime
# Beijing-region keys can leave this unset for the default intl endpoint.
QWEN_WS_URL=

# Realtime voice session (native WebSocket protocol).
QWEN_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_VOICE=Ethan

# Non-realtime models (OpenAI-compatible chat completions). Defaults shown.
# QWEN_VISION_MODEL=qwen3.7-plus
# QWEN_REASONING_MODEL=qwen3.7-max
# QWEN_OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Maps (REQUIRED for the SPA to render the map) ────────────────────────────
# Build-time arg — restrict this key to the demo origin; it is visible in the
# JS bundle (the Maps JS SDK runs in the browser).
VITE_GOOGLE_MAPS_API_KEY=
# Optional Vector Map ID (3D buildings). Blank = raster map.
VITE_GOOGLE_MAPS_MAP_ID=
VITE_GMAPS_VERSION=weekly

# Server-side Static Maps key — survey planner mission previews (optional).
STATIC_MAPS_API_KEY=

# ── Public-demo basic auth (OPTIONAL — Caddy sidecar only) ─────────────────
# When BOTH are set, alibaba/deploy.sh injects a `basic_auth` block into the
# Caddyfile so the deployed demo requires credentials. Judges get the pair
# via the Devpost Testing Instructions field. Unset both to leave the demo
# publicly accessible (default for local docker-compose runs).
DEMO_USER=
DEMO_PASSWORD=

# ── Camera / projection (cosmetic in SITL — no real video) ───────────────────
CAMERA_HFOV_DEG=69

# ── SITL knobs (defaults are Bengaluru; override only for a different home) ──
# PX4_HOME_LAT=25.35338
# PX4_HOME_LON=55.38043
# PX4_HOME_ALT=5
# OUTRIDER_HOME_LAT=25.353425
# OUTRIDER_HOME_LON=55.380434
# OUTRIDER_HOME_ALT=5
